{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WiFiKey2",
  "version": "0.3.9",
  "identifier": "com.wifikey2.server",
  "build": {
    "frontendDist": "../src-frontend",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WiFiKey2",
        "width": 450,
        "height": 350,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "WiFiKey2",
    "copyright": "Copyright © 2026 Minoru Tomobe",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Japanese", "English"],
        "installMode": "currentUser"
      }
    },
    "resources": {
      "../scripts/*": "scripts/"
    }
  },
  "plugins": {}
}
