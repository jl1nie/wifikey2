{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for WiFiKey2",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "log:default",
    "core:event:default",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-title"
  ]
}
